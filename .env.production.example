# ── Pitchr Production Environment Variables ────────────────
# Copy this file to .env on your VPS and fill in real values.
#   cp .env.production.example .env && nano .env

NODE_ENV=production

# ── Admin ────────────────────────────────────────────────
# Comma-separated emails with admin dashboard access
ADMIN_EMAILS=

# ── Domain ─────────────────────────────────────────────────
FRONTEND_URL=https://pitchr.com.ng
API_URL=https://api.pitchr.com.ng

# ── Database ───────────────────────────────────────────────
POSTGRES_USER=pitchr
# ⚠️  MUST CHANGE
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=pitchr

# ── JWT (generate with: openssl rand -hex 32) ─────────────
JWT_SECRET=change-this-to-a-long-random-string

# ── AI (DeepSeek) ─────────────────────────────────────────
# ⚠️  MUST CHANGE — leaving this returns fake/mock proposals
DEEPSEEK_API_KEY=sk-placeholder
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7

# ── Payments (Flutterwave) ────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxx

# ── Auth (SuperTokens) ────────────────────────────────────
# ⚠️  MUST CHANGE — leaving this breaks Google sign-in
# REQUIRED: Must be set. Generate with: openssl rand -hex 32
# Must match the value in docker-compose.yml under API_KEYS
SUPERTOKENS_API_KEY=placeholder

# ── Google OAuth ──────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URIs:
#    https://pitchr.com.ng/api/auth/callback/google (SuperTokens backend callback)
#    https://pitchr.com.ng/auth/callback (frontend redirect page)
# 4. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# ── Email (ZeptoMail) ─────────────────────────────────────
ZEPTOMAIL_API_KEY=placeholder
ZEPTOMAIL_FROM=noreply@pitchr.com.ng

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
